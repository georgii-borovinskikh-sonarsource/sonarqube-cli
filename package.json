{
  "name": "sonarqube-cli",
  "type": "module",
  "version": "0.11.0",
  "description": "SonarQube CLI",
  "bin": {
    "sonar": "./dist/index.js"
  },
  "scripts": {
    "build:binary": "bun build src/index.ts --compile --outfile dist/sonarqube-cli",
    "postbuild:binary": "bun build-scripts/codesign-local.ts",
    "dev": "bun run src/index.ts",
    "test:unit": "SONARQUBE_CLI_DISABLE_SENTRY=1 bun test --parallel ./tests/unit/",
    "pretest:integration": "bun build:binary && bun build-scripts/setup-integration-resources.ts",
    "test:integration": "bun test ./tests/integration/",
    "test:all": "bun run test:unit && bun run test:integration",
    "test:e2e": "bun test ./tests/e2e/",
    "test:coverage": "bun build:binary && bun build-scripts/build-coverage-binary.ts && bun build-scripts/setup-integration-resources.ts && bun build-scripts/clear-coverage-raw.ts && bun test --parallel --coverage --coverage-reporter=lcov --coverage-dir=tests/coverage/reports/unit ./tests/unit/ && SONARQUBE_CLI_USE_COVERAGE=1 bun test ./tests/integration/ && bun build-scripts/report-coverage.ts",
    "lint": "eslint src/ tests/ build-scripts/",
    "lint:fix": "eslint src/ tests/ build-scripts/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"build-scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"build-scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "gen:docs": "bun run build-scripts/docs/generate-docs.ts",
    "version:build_number": "bun build-scripts/set-build-number.ts",
    "fetch:signatures": "bun build-scripts/fetch-signatures.ts",
    "sentry:upload-sourcemaps": "sentry-cli sourcemaps upload --release=\"${PROJECT_VERSION}\" dist/*.map",
    "prepare": "husky"
  },
  "externalBinaries": {
    "sonar-secrets": {
      "version": "2.41.0.10709",
      "binaryPath": "CommercialDistribution/sonar-secrets",
      "platforms": [
        {
          "os": "linux",
          "arch": "x86-64"
        },
        {
          "os": "linux",
          "arch": "arm64"
        },
        {
          "os": "macos",
          "arch": "arm64"
        },
        {
          "os": "windows",
          "arch": "x86-64"
        }
      ]
    }
  },
  "dependencies": {
    "@clack/core": "^1.0.1",
    "@sentry/bun": "^10.46.0",
    "@toon-format/toon": "^2.1.0",
    "commander": "^14.0.0",
    "js-yaml": "^4.1.1",
    "openpgp": "^6.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@sentry/cli": "3.4.0",
    "@sonar/scan": "^4.3.5",
    "@types/bun": "^1.3.9",
    "@types/istanbul-lib-coverage": "2.0.6",
    "@types/istanbul-lib-instrument": "1.7.8",
    "@types/istanbul-lib-report": "3.0.3",
    "@types/istanbul-reports": "3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "ajv": "^8.18.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-headers": "^1.3.4",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "9.1.7",
    "istanbul-lib-instrument": "6.0.3",
    "istanbul-lib-report": "3.0.1",
    "istanbul-reports": "3.2.0",
    "lint-staged": "16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
